<div class="nav-item nav-item-com-novo px-3">
    <NavLink class="nav-link" href="@Href">
        @if (!string.IsNullOrEmpty(IconeNome))
        {
            <Icone Nome="@IconeNome" Classe="me-2" />
        }
        @Texto
    </NavLink>
    <a class="btn-novo-link"
       href="@($"{Href}?novo={Guid.NewGuid():N}")"
       title="@($"Adicionar novo: {Texto}")">
        <Icone Nome="mais" Tamanho="1.1em" />
    </a>
</div>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Texto { get; set; } = string.Empty;
    [Parameter] public string? IconeNome { get; set; }
}
