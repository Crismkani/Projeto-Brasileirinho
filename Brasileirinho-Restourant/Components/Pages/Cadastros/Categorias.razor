@page "/cadastros/categorias"
@rendermode InteractiveServer

@inject IServicoBase<Categoria> Servico

<PageTitle>Categorias</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Categorias</h1>
    <button class="btn btn-primary" @onclick="AbrirNovo">
        <i class="bi bi-plus-lg"></i> Novo
    </button>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-6">
        <input class="form-control" placeholder="Filtrar por nome..."
               @bind="filtro" @bind:event="oninput" @bind:after="CarregarAsync" />
    </div>
    <div class="col-md-3">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" id="ativos"
                   @bind="apenasAtivos" @bind:after="CarregarAsync" />
            <label class="form-check-label" for="ativos">Apenas ativos</label>
        </div>
    </div>
</div>

<TabelaListagem TItem="Categoria"
                Itens="@itens"
                Cabecalhos="@(new[] { "Id", "Nome", "Ativo" })">
    <LinhaTemplate>
        <td>@context.Id</td>
        <td>@context.Nome</td>
        <td>
            @if (context.Ativo)
            { <span class="badge bg-success">Ativo</span> }
            else
            { <span class="badge bg-secondary">Inativo</span> }
        </td>
    </LinhaTemplate>
    <AcoesTemplate>
        <BotoesAcaoCadastro Ativo="@context.Ativo"
                            AoEditar="() => AbrirEdicao(context)"
                            AoInativar="() => InativarAsync(context.Id)"
                            AoReativar="() => ReativarAsync(context.Id)"
                            AoExcluir="() => AbrirConfirmExcluir(context)" />
    </AcoesTemplate>
</TabelaListagem>

<DialogoDuplicado TItem="Categoria"
                  Visivel="@dialogoDuplicadoAberto"
                  Itens="@duplicados"
                  Processando="@salvando"
                  AoConfirmar="SalvarMesmoComDuplicado"
                  AoCancelar="() => dialogoDuplicadoAberto = false" />

<ConfirmDialog Visivel="@confirmExcluirAberto"
               Titulo="Excluir Categoria"
               TextoConfirmar="Excluir definitivo"
               Processando="@excluindo"
               MensagemErro="@erroExcluir"
               AoConfirmar="ConfirmarExcluirAsync"
               AoCancelar="() => confirmExcluirAberto = false">
    <p>Tem certeza que deseja excluir <strong>@(itemParaExcluir?.Nome)</strong>?</p>
    <p class="text-muted small mb-0">
        Esta ação <strong>não pode ser desfeita</strong>. Se este registro estiver em uso,
        prefira <em>inativar</em> ao invés de excluir.
    </p>
</ConfirmDialog>

<ModalCrud Visivel="@modalAberto"
           Titulo="@(editando.Id == 0 ? "Nova Categoria" : "Editar Categoria")"
           MensagemErro="@erro"
           Salvando="@salvando"
           ExigeConfirmacao="@(editando.Id != 0)"
           AoFechar="FecharModal"
           AoConfirmar="SalvarAsync">
    <div class="mb-3">
        <label class="form-label">Nome <span class="text-danger">*</span></label>
        <input class="form-control" maxlength="60" @bind="editando.Nome" />
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="ativoEdit" @bind="editando.Ativo" />
        <label class="form-check-label" for="ativoEdit">Ativo</label>
    </div>
</ModalCrud>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "novo")]
    public string? NovoQuery { get; set; }
    private string? _novoProcessado;

    private IReadOnlyList<Categoria> itens = Array.Empty<Categoria>();
    private string? filtro;
    private bool apenasAtivos;
    private bool modalAberto;
    private bool salvando;
    private string? erro;
    private Categoria editando = new();

    protected override void OnParametersSet()
    {
        if (NovoQuery is not null && NovoQuery != _novoProcessado)
        {
            _novoProcessado = NovoQuery;
            AbrirNovo();
        }
    }

    protected override Task OnInitializedAsync() => CarregarAsync();

    private async Task CarregarAsync()
    {
        itens = await Servico.ListarAsync(apenasAtivos, filtro);
    }

    private void AbrirNovo()
    {
        editando = new Categoria { Ativo = true };
        erro = null;
        modalAberto = true;
    }

    private void AbrirEdicao(Categoria item)
    {
        editando = new Categoria
        {
            Id = item.Id,
            Nome = item.Nome,
            Ativo = item.Ativo
        };
        erro = null;
        modalAberto = true;
    }

    private void FecharModal() => modalAberto = false;

    private async Task SalvarAsync()
    {
        salvando = true; erro = null;
        try
        {
            if (!forcarDuplicado)
            {
                var dups = await Servico.BuscarDuplicadosPorNomeAsync(editando);
                if (dups.Count > 0)
                {
                    duplicados = dups;
                    dialogoDuplicadoAberto = true;
                    return;
                }
            }
            forcarDuplicado = false;

            await Servico.SalvarAsync(editando);
            modalAberto = false;
            await CarregarAsync();
        }
        catch (Exception ex) { erro = MensagensErro.Para(ex); }
        finally { salvando = false; }
    }

    private bool dialogoDuplicadoAberto;
    private bool forcarDuplicado;
    private IReadOnlyList<Categoria> duplicados = Array.Empty<Categoria>();

    private async Task SalvarMesmoComDuplicado()
    {
        forcarDuplicado = true;
        dialogoDuplicadoAberto = false;
        await SalvarAsync();
    }

    private async Task InativarAsync(long id)
    {
        await Servico.InativarAsync(id);
        await CarregarAsync();
    }

    private async Task ReativarAsync(long id)
    {
        await Servico.ReativarAsync(id);
        await CarregarAsync();
    }

    private bool confirmExcluirAberto;
    private bool excluindo;
    private string? erroExcluir;
    private Categoria? itemParaExcluir;

    private void AbrirConfirmExcluir(Categoria item)
    {
        itemParaExcluir = item;
        erroExcluir = null;
        confirmExcluirAberto = true;
    }

    private async Task ConfirmarExcluirAsync()
    {
        if (itemParaExcluir is null) return;

        excluindo = true; erroExcluir = null;
        try
        {
            await Servico.ExcluirDefinitivoAsync(itemParaExcluir.Id);
            confirmExcluirAberto = false;
            itemParaExcluir = null;
            await CarregarAsync();
        }
        catch (Exception ex)
        {
            erroExcluir = MensagensErro.Para(ex);
        }
        finally { excluindo = false; }
    }
}
