@page "/cadastros/condicoes-pagamento"
@rendermode InteractiveServer

@inject IServicoBase<CondicaoPagamento> Servico

<PageTitle>Condições de Pagamento</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Condições de Pagamento</h1>
    <button class="btn btn-primary" @onclick="AbrirNovo">Novo</button>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-6">
        <input class="form-control" placeholder="Filtrar..."
               @bind="filtro" @bind:event="oninput" @bind:after="CarregarAsync" />
    </div>
    <div class="col-md-3">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" id="ativos"
                   @bind="apenasAtivos" @bind:after="CarregarAsync" />
            <label class="form-check-label" for="ativos">Apenas ativos</label>
        </div>
    </div>
</div>

<TabelaListagem TItem="CondicaoPagamento"
                Itens="@itens"
                Cabecalhos="@(new[] { "Id", "Nome", "Parcelas", "Prazo (dias)", "Juros (%)", "Ativo" })">
    <LinhaTemplate>
        <td>@context.Id</td>
        <td>
            <div>@context.Nome</div>
            @if (!string.IsNullOrWhiteSpace(context.Descricao))
            {
                <small class="text-muted">@context.Descricao</small>
            }
        </td>
        <td>@context.NumeroParcelas x</td>
        <td>@context.PrazoDias</td>
        <td>@context.TaxaJuros.ToString("N2") %</td>
        <td>
            @if (context.Ativo)
            { <span class="badge bg-success">Ativo</span> }
            else
            { <span class="badge bg-secondary">Inativo</span> }
        </td>
    </LinhaTemplate>
    <AcoesTemplate>
        <BotoesAcaoCadastro Ativo="@context.Ativo"
                            AoEditar="() => AbrirEdicao(context)"
                            AoInativar="() => InativarAsync(context.Id)"
                            AoReativar="() => ReativarAsync(context.Id)"
                            AoExcluir="() => AbrirConfirmExcluir(context)" />
    </AcoesTemplate>
</TabelaListagem>

<DialogoDuplicado TItem="CondicaoPagamento"
                  Visivel="@dialogoDuplicadoAberto"
                  Itens="@duplicados"
                  Processando="@salvando"
                  AoConfirmar="SalvarMesmoComDuplicado"
                  AoCancelar="() => dialogoDuplicadoAberto = false" />

<ConfirmDialog Visivel="@confirmExcluirAberto"
               Titulo="Excluir Condição de Pagamento"
               TextoConfirmar="Excluir definitivo"
               Processando="@excluindo"
               MensagemErro="@erroExcluir"
               AoConfirmar="ConfirmarExcluirAsync"
               AoCancelar="() => confirmExcluirAberto = false">
    <p>Tem certeza que deseja excluir <strong>@(itemParaExcluir?.Nome)</strong>?</p>
    <p class="text-muted small mb-0">
        Esta ação <strong>não pode ser desfeita</strong>. Vendas ou fornecedores que usam essa condição
        bloqueiam a exclusão — prefira inativar.
    </p>
</ConfirmDialog>

<ModalCrud Visivel="@modalAberto"
           Titulo="@(editando.Id == 0 ? "Nova Condição de Pagamento" : "Editar Condição de Pagamento")"
           MensagemErro="@erro"
           Salvando="@salvando"
           ExigeConfirmacao="@(editando.Id != 0)"
           AoFechar="FecharModal"
           AoConfirmar="SalvarAsync">
    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Nome <span class="text-danger">*</span></label>
            <input class="form-control" maxlength="100" @bind="editando.Nome"
                   placeholder="Ex: À Vista, 30 dias, 2x sem juros" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Parcelas <span class="text-danger">*</span></label>
            <input type="number" min="1" class="form-control" @bind="editando.NumeroParcelas" />
        </div>
        <div class="col-md-12">
            <label class="form-label">Descrição</label>
            <input class="form-control" maxlength="200" @bind="editando.Descricao"
                   placeholder="Descrição opcional" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Prazo (dias) <span class="text-danger">*</span></label>
            <input type="number" min="0" class="form-control" @bind="editando.PrazoDias"
                   placeholder="0 = à vista" />
            <small class="text-muted">0 = à vista</small>
        </div>
        <div class="col-md-6">
            <label class="form-label">Taxa de juros (%) <span class="text-danger">*</span></label>
            <input type="number" min="0" step="0.01" class="form-control" @bind="editando.TaxaJuros"
                   placeholder="0.00 = sem juros" />
            <small class="text-muted">0 = sem juros</small>
        </div>
        <div class="col-12">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="ativoCondPag" @bind="editando.Ativo" />
                <label class="form-check-label" for="ativoCondPag">Ativo</label>
            </div>
        </div>
    </div>
</ModalCrud>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "novo")]
    public string? NovoQuery { get; set; }
    private string? _novoProcessado;

    protected override void OnParametersSet()
    {
        if (NovoQuery is not null && NovoQuery != _novoProcessado)
        {
            _novoProcessado = NovoQuery;
            AbrirNovo();
        }
    }

    private IReadOnlyList<CondicaoPagamento> itens = Array.Empty<CondicaoPagamento>();
    private string? filtro;
    private bool apenasAtivos;
    private bool modalAberto;
    private bool salvando;
    private string? erro;
    private CondicaoPagamento editando = new();

    protected override Task OnInitializedAsync() => CarregarAsync();

    private async Task CarregarAsync() => itens = await Servico.ListarAsync(apenasAtivos, filtro);

    private void AbrirNovo()
    {
        editando = new CondicaoPagamento { Ativo = true, NumeroParcelas = 1 };
        erro = null; modalAberto = true;
    }

    private void AbrirEdicao(CondicaoPagamento c)
    {
        editando = new CondicaoPagamento
        {
            Id = c.Id, Nome = c.Nome, Descricao = c.Descricao,
            NumeroParcelas = c.NumeroParcelas, PrazoDias = c.PrazoDias,
            TaxaJuros = c.TaxaJuros, Ativo = c.Ativo
        };
        erro = null; modalAberto = true;
    }

    private void FecharModal() => modalAberto = false;

    private async Task SalvarAsync()
    {
        salvando = true; erro = null;
        try
        {
            if (editando.NumeroParcelas < 1)
                throw new InvalidOperationException("Número de parcelas deve ser pelo menos 1.");
            if (editando.PrazoDias < 0)
                throw new InvalidOperationException("Prazo em dias não pode ser negativo.");
            if (editando.TaxaJuros < 0)
                throw new InvalidOperationException("Taxa de juros não pode ser negativa.");

            if (!forcarDuplicado)
            {
                var dups = await Servico.BuscarDuplicadosPorNomeAsync(editando);
                if (dups.Count > 0) { duplicados = dups; dialogoDuplicadoAberto = true; return; }
            }
            forcarDuplicado = false;

            await Servico.SalvarAsync(editando);
            modalAberto = false;
            await CarregarAsync();
        }
        catch (Exception ex) { erro = MensagensErro.Para(ex); }
        finally { salvando = false; }
    }

    private bool dialogoDuplicadoAberto, forcarDuplicado;
    private IReadOnlyList<CondicaoPagamento> duplicados = Array.Empty<CondicaoPagamento>();
    private async Task SalvarMesmoComDuplicado()
    {
        forcarDuplicado = true; dialogoDuplicadoAberto = false;
        await SalvarAsync();
    }

    private async Task InativarAsync(long id) { await Servico.InativarAsync(id); await CarregarAsync(); }
    private async Task ReativarAsync(long id) { await Servico.ReativarAsync(id); await CarregarAsync(); }

    private bool confirmExcluirAberto;
    private bool excluindo;
    private string? erroExcluir;
    private CondicaoPagamento? itemParaExcluir;

    private void AbrirConfirmExcluir(CondicaoPagamento item)
    {
        itemParaExcluir = item;
        erroExcluir = null;
        confirmExcluirAberto = true;
    }

    private async Task ConfirmarExcluirAsync()
    {
        if (itemParaExcluir is null) return;
        excluindo = true; erroExcluir = null;
        try
        {
            await Servico.ExcluirDefinitivoAsync(itemParaExcluir.Id);
            confirmExcluirAberto = false;
            itemParaExcluir = null;
            await CarregarAsync();
        }
        catch (Exception ex) { erroExcluir = MensagensErro.Para(ex); }
        finally { excluindo = false; }
    }
}
