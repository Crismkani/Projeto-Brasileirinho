@page "/financeiro/contas-pagar"
@rendermode InteractiveServer

@inject IServicoContasPagar Servico
@inject IServicoBase<Fornecedor> ServicoFornecedor
@inject IServicoBase<FormaPagamento> ServicoFormaPagamento
@inject IArmazenamentoNotas Notas

<PageTitle>Contas a Pagar</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Contas a Pagar</h1>
    <button class="btn btn-primary" @onclick="AbrirNova">+ Nova Conta</button>
</div>

@if (resumo is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card border-warning text-center py-2">
                <div class="card-body p-2">
                    <div class="text-muted small">Pendente</div>
                    <div class="fs-4 fw-bold text-warning">@resumo.Pendente.ToString("C")</div>
                    <div class="text-muted small">@resumo.QtdPendente contas</div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-danger text-center py-2">
                <div class="card-body p-2">
                    <div class="text-muted small">Atrasado</div>
                    <div class="fs-4 fw-bold text-danger">@resumo.Atrasado.ToString("C")</div>
                    <div class="text-muted small">@resumo.QtdAtrasado contas</div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-success text-center py-2">
                <div class="card-body p-2">
                    <div class="text-muted small">Pago (período filtrado)</div>
                    <div class="fs-4 fw-bold text-success">@resumo.Pago.ToString("C")</div>
                    <div class="text-muted small">@resumo.QtdPago contas</div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <input class="form-control" placeholder="Buscar por nº documento ou descrição..."
               @bind="filtroTexto" @bind:event="oninput" @bind:after="CarregarAsync" />
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="filtroStatus" @bind:after="CarregarAsync">
            <option value="">Todos os status</option>
            <option value="Pendente">Pendente</option>
            <option value="Atrasado">Atrasado</option>
            <option value="Pago">Pago</option>
            <option value="Cancelado">Cancelado</option>
        </select>
    </div>
    <div class="col-md-2">
        <input type="date" class="form-control" @bind="filtroVencDe" @bind:after="CarregarAsync" />
    </div>
    <div class="col-md-2">
        <input type="date" class="form-control" @bind="filtroVencAte" @bind:after="CarregarAsync" />
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="filtroFornecedorId" @bind:after="CarregarAsync">
            <option value="0">Todos os fornecedores</option>
            @foreach (var f in fornecedores)
            {
                <option value="@f.Id">@f.Nome</option>
            }
        </select>
    </div>
    <div class="col-md-1">
        <button class="btn btn-outline-secondary w-100" @onclick="LimparFiltros" title="Limpar filtros">✕</button>
    </div>
</div>

@if (mensagem is not null)
{
    <div class="alert @classeMensagem alert-dismissible mb-3">
        @mensagem
        <button type="button" class="btn-close" @onclick="() => mensagem = null"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Nº Doc.</th>
                <th>Descrição</th>
                <th>Fornecedor</th>
                <th>Vencimento</th>
                <th class="text-end">Valor</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!itens.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-4">Nenhuma conta encontrada.</td></tr>
            }
            @foreach (var c in itens)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(c.NumeroDocumento))
                        {
                            <code class="small">@c.NumeroDocumento</code>
                        }
                        else
                        {
                            <span class="text-muted small">—</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(c.ArquivoNota))
                        {
                            <a href="@c.ArquivoNota" target="_blank" class="ms-1" title="Ver nota anexada">📎</a>
                        }
                    </td>
                    <td>
                        <div>@c.Descricao</div>
                        @if (!string.IsNullOrWhiteSpace(c.Observacao))
                        {
                            <small class="text-muted">@c.Observacao</small>
                        }
                    </td>
                    <td>@(c.Fornecedor?.Nome ?? "—")</td>
                    <td class="@(c.Atrasado ? "text-danger fw-semibold" : "")">
                        @c.DataVencimento.ToString("dd/MM/yyyy")
                    </td>
                    <td class="text-end fw-semibold">@c.Valor.ToString("C")</td>
                    <td>@BadgeStatus(c)</td>
                    <td>
                        <div class="d-flex gap-1 justify-content-end">
                            @if (c.Status == StatusContaPagar.Pendente)
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => AbrirPagamento(c)"
                                        title="Registrar pagamento">Pagar</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => AbrirEdicao(c)"
                                        title="Editar">✏</button>
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => AbrirCancelar(c)"
                                        title="Cancelar">✕</button>
                            }
                            @if (c.Status == StatusContaPagar.Pago)
                            {
                                <span class="text-muted small">@c.DataPagamento?.ToString("dd/MM") — @c.ValorPago?.ToString("C")</span>
                            }
                            @if (c.Status != StatusContaPagar.Pago)
                            {
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => AbrirExcluir(c)"
                                        title="Excluir">🗑</button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal Nova/Editar Conta -->
<ModalCrud Visivel="@modalAberto"
           Titulo="@(editando.Id == 0 ? "Nova Conta a Pagar" : "Editar Conta a Pagar")"
           MensagemErro="@erro"
           Salvando="@salvando"
           ExigeConfirmacao="@(editando.Id != 0)"
           AoFechar="FecharModal"
           AoConfirmar="SalvarAsync">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Nº do Documento</label>
            <input class="form-control" maxlength="50" @bind="editando.NumeroDocumento"
                   placeholder="NF 001234, Boleto..." />
        </div>
        <div class="col-md-8">
            <label class="form-label">Descrição <span class="text-danger">*</span></label>
            <input class="form-control" maxlength="255" @bind="editando.Descricao" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Fornecedor</label>
            <select class="form-select" @bind="editando.FornecedorId">
                <option value="">— Nenhum —</option>
                @foreach (var f in fornecedores)
                {
                    <option value="@f.Id">@f.Nome</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">Valor <span class="text-danger">*</span></label>
            <input type="number" step="0.01" class="form-control"
                   @bind="editando.Valor"
                   @bind:culture="System.Globalization.CultureInfo.InvariantCulture" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Emissão <span class="text-danger">*</span></label>
            <input type="date" class="form-control" @bind="editando.DataEmissao" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Vencimento <span class="text-danger">*</span></label>
            <input type="date" class="form-control" @bind="editando.DataVencimento"
                   min="@editando.DataEmissao.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-12">
            <label class="form-label">Observação</label>
            <input class="form-control" maxlength="500" @bind="editando.Observacao" />
        </div>
        <div class="col-md-12">
            <label class="form-label">Anexar Nota (PDF, JPG, PNG — máx. 10 MB)</label>
            @if (!string.IsNullOrWhiteSpace(editando.ArquivoNota))
            {
                <div class="d-flex align-items-center gap-2 mb-1">
                    <a href="@editando.ArquivoNota" target="_blank" class="btn btn-sm btn-outline-primary">
                        📎 Ver nota atual
                    </a>
                    <button type="button" class="btn btn-sm btn-outline-danger"
                            @onclick="RemoverArquivoAtual">Remover</button>
                </div>
            }
            <InputFile OnChange="HandleUploadNota" class="form-control form-control-sm"
                       accept=".pdf,image/png,image/jpeg,image/webp"
                       disabled="@uploadando" />
            @if (uploadando)
            {
                <small class="text-muted">Enviando...</small>
            }
            @if (!string.IsNullOrWhiteSpace(erroUpload))
            {
                <small class="text-danger">@erroUpload</small>
            }
        </div>
    </div>
</ModalCrud>

<!-- Modal Registrar Pagamento -->
<ModalCrud Visivel="@modalPagamentoAberto"
           Titulo="Registrar Pagamento"
           MensagemErro="@erroPagamento"
           Salvando="@salvando"
           AoFechar="() => modalPagamentoAberto = false"
           AoConfirmar="ConfirmarPagamentoAsync">
    <div class="row g-3">
        <div class="col-md-12">
            <div class="alert alert-secondary py-2 mb-0">
                <strong>@contaPagando?.Descricao</strong>
                <span class="ms-2">— Valor: @contaPagando?.Valor.ToString("C")</span>
            </div>
        </div>
        <div class="col-md-6">
            <label class="form-label">Data do Pagamento <span class="text-danger">*</span></label>
            <input type="date" class="form-control" @bind="pagDataPagamento" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Valor Pago <span class="text-danger">*</span></label>
            <input type="number" step="0.01" class="form-control"
                   @bind="pagValorPago"
                   @bind:culture="System.Globalization.CultureInfo.InvariantCulture" />
        </div>
        <div class="col-md-12">
            <label class="form-label">Forma de Pagamento</label>
            <select class="form-select" @bind="pagFormaPagamentoId">
                <option value="">— Selecione —</option>
                @foreach (var f in formasPagamento)
                {
                    <option value="@f.Id">@f.Nome</option>
                }
            </select>
        </div>
    </div>
</ModalCrud>

<!-- Confirm Cancelar -->
<ConfirmDialog Visivel="@confirmCancelarAberto"
               Titulo="Cancelar Conta"
               TextoConfirmar="Cancelar conta"
               Processando="@salvando"
               MensagemErro="@erroConfirm"
               AoConfirmar="ConfirmarCancelarAsync"
               AoCancelar="() => confirmCancelarAberto = false">
    <p>Cancelar a conta <strong>@(contaAcao?.Descricao)</strong>?</p>
</ConfirmDialog>

<!-- Confirm Excluir -->
<ConfirmDialog Visivel="@confirmExcluirAberto"
               Titulo="Excluir Conta"
               TextoConfirmar="Excluir definitivo"
               Processando="@salvando"
               MensagemErro="@erroConfirm"
               AoConfirmar="ConfirmarExcluirAsync"
               AoCancelar="() => confirmExcluirAberto = false">
    <p>Excluir definitivamente <strong>@(contaAcao?.Descricao)</strong>?</p>
    <p class="text-muted small mb-0">Esta ação não pode ser desfeita.</p>
</ConfirmDialog>

@code {
    private IReadOnlyList<ContaPagar> itens = Array.Empty<ContaPagar>();
    private IReadOnlyList<Fornecedor> fornecedores = Array.Empty<Fornecedor>();
    private IReadOnlyList<FormaPagamento> formasPagamento = Array.Empty<FormaPagamento>();

    private string filtroTexto = "";
    private string filtroStatus = "";
    private DateOnly? filtroVencDe;
    private DateOnly? filtroVencAte;
    private long filtroFornecedorId;

    private bool uploadando;
    private string? erroUpload;

    private bool modalAberto, salvando;
    private string? erro;
    private ContaPagar editando = new();

    private bool modalPagamentoAberto;
    private string? erroPagamento;
    private ContaPagar? contaPagando;
    private DateOnly pagDataPagamento = DateOnly.FromDateTime(DateTime.Today);
    private decimal pagValorPago;
    private long? pagFormaPagamentoId;

    private bool confirmCancelarAberto, confirmExcluirAberto;
    private string? erroConfirm;
    private ContaPagar? contaAcao;

    private string? mensagem;
    private string classeMensagem = "alert-success";

    private record ResumoCards(decimal Pendente, int QtdPendente, decimal Atrasado, int QtdAtrasado, decimal Pago, int QtdPago);
    private ResumoCards? resumo;

    protected override async Task OnInitializedAsync()
    {
        fornecedores = await ServicoFornecedor.ListarAsync(somenteAtivos: true);
        formasPagamento = await ServicoFormaPagamento.ListarAsync(somenteAtivos: true);
        await CarregarAsync();
    }

    private async Task CarregarAsync()
    {
        StatusContaPagar? status = filtroStatus switch
        {
            "Pendente" => StatusContaPagar.Pendente,
            "Pago"     => StatusContaPagar.Pago,
            "Cancelado" => StatusContaPagar.Cancelado,
            _ => null
        };

        // "Atrasado" filtra pendentes com vencimento < hoje
        DateOnly? vencAte = filtroStatus == "Atrasado"
            ? DateOnly.FromDateTime(DateTime.Today.AddDays(-1))
            : filtroVencAte;

        StatusContaPagar? statusQuery = filtroStatus == "Atrasado"
            ? StatusContaPagar.Pendente
            : status;

        itens = await Servico.ListarAsync(
            status: statusQuery,
            vencimentoDe: filtroVencDe,
            vencimentoAte: vencAte,
            fornecedorId: filtroFornecedorId > 0 ? filtroFornecedorId : null,
            texto: string.IsNullOrWhiteSpace(filtroTexto) ? null : filtroTexto);

        // Sempre carregar todos pendentes/pagos para os cards de resumo
        var todos = await Servico.ListarAsync();
        var hoje = DateOnly.FromDateTime(DateTime.Today);
        resumo = new ResumoCards(
            Pendente: todos.Where(c => c.Status == StatusContaPagar.Pendente && !c.Atrasado).Sum(c => c.Valor),
            QtdPendente: todos.Count(c => c.Status == StatusContaPagar.Pendente && !c.Atrasado),
            Atrasado: todos.Where(c => c.Atrasado).Sum(c => c.Valor),
            QtdAtrasado: todos.Count(c => c.Atrasado),
            Pago: itens.Where(c => c.Status == StatusContaPagar.Pago).Sum(c => c.ValorPago ?? 0),
            QtdPago: itens.Count(c => c.Status == StatusContaPagar.Pago)
        );
    }

    private void LimparFiltros()
    {
        filtroTexto = ""; filtroStatus = ""; filtroVencDe = null; filtroVencAte = null; filtroFornecedorId = 0;
        _ = CarregarAsync();
    }

    private void AbrirNova()
    {
        editando = new ContaPagar
        {
            DataEmissao = DateOnly.FromDateTime(DateTime.Today),
            DataVencimento = DateOnly.FromDateTime(DateTime.Today),
            Ativo = true
        };
        erroUpload = null; erro = null; modalAberto = true;
    }

    private void AbrirEdicao(ContaPagar c)
    {
        editando = new ContaPagar
        {
            Id = c.Id, NumeroDocumento = c.NumeroDocumento, Descricao = c.Descricao,
            FornecedorId = c.FornecedorId, Valor = c.Valor,
            DataEmissao = c.DataEmissao, DataVencimento = c.DataVencimento,
            ArquivoNota = c.ArquivoNota, Observacao = c.Observacao,
            Status = c.Status, Ativo = c.Ativo
        };
        erroUpload = null; erro = null; modalAberto = true;
    }

    private void RemoverArquivoAtual()
    {
        Notas.Remover(editando.ArquivoNota);
        editando.ArquivoNota = null;
    }

    private async Task HandleUploadNota(InputFileChangeEventArgs e)
    {
        if (e.File is null) return;
        if (e.File.Size > ArmazenamentoNotas.MaxBytes)
        {
            erroUpload = $"Arquivo de {e.File.Size / (1024.0 * 1024.0):N1} MB excede o limite de 10 MB.";
            return;
        }
        uploadando = true; erroUpload = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var novaUrl = await Notas.SalvarAsync(e.File);
            Notas.Remover(editando.ArquivoNota);
            editando.ArquivoNota = novaUrl;
        }
        catch (Exception ex) { erroUpload = ex.Message; }
        finally { uploadando = false; }
    }

    private void FecharModal() => modalAberto = false;

    private async Task SalvarAsync()
    {
        salvando = true; erro = null;
        try
        {
            await Servico.SalvarAsync(editando);
            modalAberto = false;
            await CarregarAsync();
        }
        catch (Exception ex) { erro = MensagensErro.Para(ex); }
        finally { salvando = false; }
    }

    private void AbrirPagamento(ContaPagar c)
    {
        contaPagando = c;
        pagDataPagamento = DateOnly.FromDateTime(DateTime.Today);
        pagValorPago = c.Valor;
        pagFormaPagamentoId = null;
        erroPagamento = null;
        modalPagamentoAberto = true;
    }

    private async Task ConfirmarPagamentoAsync()
    {
        if (contaPagando is null) return;
        salvando = true; erroPagamento = null;
        try
        {
            await Servico.RegistrarPagamentoAsync(
                contaPagando.Id, pagDataPagamento, pagValorPago, pagFormaPagamentoId);
            modalPagamentoAberto = false;
            MostrarMensagem($"Pagamento de {pagValorPago:C} registrado.", "alert-success");
            await CarregarAsync();
        }
        catch (Exception ex) { erroPagamento = MensagensErro.Para(ex); }
        finally { salvando = false; }
    }

    private void AbrirCancelar(ContaPagar c) { contaAcao = c; erroConfirm = null; confirmCancelarAberto = true; }

    private async Task ConfirmarCancelarAsync()
    {
        if (contaAcao is null) return;
        salvando = true; erroConfirm = null;
        try
        {
            await Servico.CancelarAsync(contaAcao.Id);
            confirmCancelarAberto = false;
            await CarregarAsync();
        }
        catch (Exception ex) { erroConfirm = MensagensErro.Para(ex); }
        finally { salvando = false; }
    }

    private void AbrirExcluir(ContaPagar c) { contaAcao = c; erroConfirm = null; confirmExcluirAberto = true; }

    private async Task ConfirmarExcluirAsync()
    {
        if (contaAcao is null) return;
        salvando = true; erroConfirm = null;
        try
        {
            await Servico.ExcluirAsync(contaAcao.Id);
            confirmExcluirAberto = false;
            await CarregarAsync();
        }
        catch (Exception ex) { erroConfirm = MensagensErro.Para(ex); }
        finally { salvando = false; }
    }

    private void MostrarMensagem(string msg, string classe) { mensagem = msg; classeMensagem = classe; }

    private RenderFragment BadgeStatus(ContaPagar c) => c.Status switch
    {
        StatusContaPagar.Pago      => @<span class="badge bg-success">Pago</span>,
        StatusContaPagar.Cancelado => @<span class="badge bg-secondary">Cancelado</span>,
        _ when c.Atrasado          => @<span class="badge bg-danger">Atrasado</span>,
        _                          => @<span class="badge bg-warning text-dark">Pendente</span>
    };
}
