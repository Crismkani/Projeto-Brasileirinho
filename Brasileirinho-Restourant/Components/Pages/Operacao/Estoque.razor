@page "/operacao/estoque"
@rendermode InteractiveServer

@inject IServicoBase<Produto> ServicoProduto
@inject IServicoBase<UnidadeMedida> ServicoUnidade

<PageTitle>Estoque</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Gerenciamento de Estoque</h1>
    <small class="text-muted">Vendas concluídas abatem estoque automaticamente</small>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-6">
        <input class="form-control" placeholder="Filtrar produto..."
               @bind="filtro" @bind:event="oninput" @bind:after="CarregarAsync" />
    </div>
    <div class="col-md-3">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" id="apenasBaixo"
                   @bind="apenasBaixo" @bind:after="CarregarAsync" />
            <label class="form-check-label" for="apenasBaixo">Apenas estoque baixo</label>
        </div>
    </div>
</div>

<TabelaListagem TItem="Produto"
                Itens="@itens"
                Cabecalhos="@(new[] { "Foto", "Produto", "Cód. Barras", "UM", "Atual", "Mínimo", "Status" })">
    <LinhaTemplate>
        <td style="width: 60px;">
            @if (!string.IsNullOrEmpty(context.FotoUrl))
            {
                <img src="@context.FotoUrl" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" />
            }
        </td>
        <td>@context.Nome</td>
        <td><code>@context.CodigoBarras</code></td>
        <td><code>@SiglaUnidade(context.UnidadeMedidaId)</code></td>
        <td class="text-end fw-semibold">@context.Quantidade.ToString("N3")</td>
        <td class="text-end">@context.QuantidadeMinima.ToString("N3")</td>
        <td>
            @if (context.Quantidade <= 0)
            { <span class="badge bg-danger">Zerado</span> }
            else if (context.Quantidade <= context.QuantidadeMinima)
            { <span class="badge bg-warning text-dark">Baixo</span> }
            else
            { <span class="badge bg-success">OK</span> }
        </td>
    </LinhaTemplate>
    <AcoesTemplate>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => AbrirAjuste(context)">
            Ajustar
        </button>
    </AcoesTemplate>
</TabelaListagem>

<ModalCrud Visivel="@modalAberto"
           Titulo="Ajustar Estoque"
           TextoConfirmar="Aplicar ajuste"
           MensagemErro="@erro"
           Salvando="@salvando"
           AoFechar="() => modalAberto = false"
           AoConfirmar="SalvarAsync">
    @if (produtoEdit is not null)
    {
        <div class="d-flex align-items-center mb-3 p-2 bg-light rounded border">
            @if (!string.IsNullOrEmpty(produtoEdit.FotoUrl))
            {
                <img src="@produtoEdit.FotoUrl" style="width: 56px; height: 56px; object-fit: cover; border-radius: 6px;" class="me-3 border bg-white" />
            }
            <div>
                <strong>@produtoEdit.Nome</strong>
                <small class="d-block text-muted">
                    Atual: <strong>@produtoEdit.Quantidade.ToString("N3")</strong> @SiglaUnidade(produtoEdit.UnidadeMedidaId)
                </small>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-12">
                <label class="form-label">Tipo de movimento</label>
                <div class="btn-group w-100" role="group">
                    <input type="radio" class="btn-check" name="tipoMov" id="movEnt"
                           checked="@(tipo == TipoMovimento.Entrada)"
                           @onchange="() => MudarTipo(TipoMovimento.Entrada)" />
                    <label class="btn btn-outline-success" for="movEnt">Entrada (+)</label>

                    <input type="radio" class="btn-check" name="tipoMov" id="movSai"
                           checked="@(tipo == TipoMovimento.Saida)"
                           @onchange="() => MudarTipo(TipoMovimento.Saida)" />
                    <label class="btn btn-outline-danger" for="movSai">Saída (−)</label>

                    <input type="radio" class="btn-check" name="tipoMov" id="movAju"
                           checked="@(tipo == TipoMovimento.Ajuste)"
                           @onchange="() => MudarTipo(TipoMovimento.Ajuste)" />
                    <label class="btn btn-outline-primary" for="movAju">Ajuste manual (=)</label>
                </div>
            </div>

            <div class="col-md-6">
                <label class="form-label">
                    @(tipo == TipoMovimento.Ajuste ? "Nova quantidade (estoque final)" : "Quantidade da movimentação")
                    <span class="text-danger">*</span>
                </label>
                <input type="number" step="0.001" min="0" class="form-control"
                       @bind="quantidadeMov" @bind:event="oninput" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Estoque mínimo</label>
                <input type="number" step="0.001" min="0" class="form-control"
                       @bind="quantidadeMinima" />
            </div>

            <div class="col-md-12">
                <div class="alert alert-secondary mb-0 py-2">
                    Estoque após o ajuste:
                    <strong class="fs-5 @(EstoqueFinal < 0 ? "text-danger" : "")">
                        @EstoqueFinal.ToString("N3")
                    </strong>
                    @SiglaUnidade(produtoEdit.UnidadeMedidaId)
                </div>
            </div>
        </div>
    }
</ModalCrud>

@code {
    private enum TipoMovimento { Entrada, Saida, Ajuste }

    private IReadOnlyList<Produto> itens = Array.Empty<Produto>();
    private IReadOnlyList<UnidadeMedida> unidades = Array.Empty<UnidadeMedida>();
    private string? filtro;
    private bool apenasBaixo;

    private bool modalAberto, salvando;
    private string? erro;
    private Produto? produtoEdit;
    private TipoMovimento tipo = TipoMovimento.Entrada;
    private decimal quantidadeMov;
    private decimal quantidadeMinima;

    protected override async Task OnInitializedAsync()
    {
        unidades = await ServicoUnidade.ListarAsync(somenteAtivos: true);
        await CarregarAsync();
    }

    private async Task CarregarAsync()
    {
        var todos = await ServicoProduto.ListarAsync(somenteAtivos: true, filtroTexto: filtro);
        itens = apenasBaixo
            ? todos.Where(p => p.Quantidade <= p.QuantidadeMinima).ToList()
            : todos;
    }

    private string SiglaUnidade(long id)
        => unidades.FirstOrDefault(u => u.Id == id)?.Sigla ?? "";

    private decimal EstoqueFinal => produtoEdit is null ? 0m : tipo switch
    {
        TipoMovimento.Entrada => produtoEdit.Quantidade + quantidadeMov,
        TipoMovimento.Saida   => produtoEdit.Quantidade - quantidadeMov,
        TipoMovimento.Ajuste  => quantidadeMov,
        _ => produtoEdit.Quantidade
    };

    private void AbrirAjuste(Produto p)
    {
        produtoEdit = p;
        tipo = TipoMovimento.Entrada;
        quantidadeMov = 0m;
        quantidadeMinima = p.QuantidadeMinima;
        erro = null;
        modalAberto = true;
    }

    private void MudarTipo(TipoMovimento novo)
    {
        tipo = novo;
        quantidadeMov = 0m;
    }

    private async Task SalvarAsync()
    {
        if (produtoEdit is null) return;

        salvando = true; erro = null;
        try
        {
            if (quantidadeMov < 0)
                throw new InvalidOperationException("Quantidade não pode ser negativa.");

            var final = EstoqueFinal;
            if (final < 0)
                throw new InvalidOperationException("Estoque final ficaria negativo.");

            var produtoCompleto = await ServicoProduto.ObterPorIdAsync(produtoEdit.Id)
                ?? throw new InvalidOperationException("Produto não encontrado.");

            produtoCompleto.Quantidade = final;
            produtoCompleto.QuantidadeMinima = quantidadeMinima;

            await ServicoProduto.SalvarAsync(produtoCompleto);
            modalAberto = false;
            await CarregarAsync();
        }
        catch (Exception ex) { erro = MensagensErro.Para(ex); }
        finally { salvando = false; }
    }
}
